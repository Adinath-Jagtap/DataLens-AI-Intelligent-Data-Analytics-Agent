// =============================================
// FIRESTORE SECURITY RULES
// Project: datalens-ai
// =============================================

// 🔒 SECURE RULES
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Allow read own doc OR if requester is admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Allow list for admins (collection query)
      allow list: if isAdmin();
      // Create: authenticated user creates their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Update: user can update own doc, admin can update any
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Delete: not allowed
      allow delete: if false;

      // Analyses subcollection
      match /analyses/{analysisId} {
        // User can read own analyses, admin can read all
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        // User can list own analyses, admin can list all
        allow list: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        // User can create in their own directory
        allow create: if isAuthenticated() && request.auth.uid == userId;
        // User can update own analyses, admin can update any
        allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        // User can delete own analyses, admin can delete any
        allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
